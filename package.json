{
  "name": "typescript-lambda-starter",
  "version": "0.1.0",
  "description": "Production-grade TypeScript starter template for AWS Lambda.",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run clean && node scripts/build.mjs && tsc -p tsconfig.build.json",
    "build:watch": "node scripts/build.mjs --watch",
    "clean": "rimraf dist coverage cdk.out",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules --enable-source-maps node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "node --experimental-vm-modules --enable-source-maps node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules --enable-source-maps node_modules/jest/bin/jest.js --coverage --runInBand",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "cdk": "cdk",
    "cdk:synth": "npm run build && cdk synth",
    "cdk:deploy": "npm run build && cdk deploy",
    "ci": "npm run lint && npm run format:check && npm run test:coverage && npm run build && npm run cdk:synth"
  },
  "dependencies": {
    "@aws-lambda-powertools/jmespath": "^2.33.1",
    "@aws-lambda-powertools/logger": "^2.33.1",
    "@aws-lambda-powertools/metrics": "^2.33.1",
    "@aws-lambda-powertools/tracer": "^2.33.1",
    "@aws-sdk/client-ssm": "^3.1069.0",
    "@aws/durable-execution-sdk-js": "^1.1.7",
    "@middy/core": "^7.6.7",
    "aws-cdk-lib": "^2.259.0",
    "constructs": "^10.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@swc/core": "^1.15.41",
    "@swc/jest": "^0.2.39",
    "@types/aws-lambda": "^8.10.162",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "aws-cdk": "^2.1127.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
